// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// # 스키마 수정 후 DB 반영
// pnpm prisma migrate dev --name xxx
// migrate dev -> 마이그레이션 파일 생성 + DB에 반영 + prisma client 재생성
// migrate deploy -> 마이그레이션 파일 생성 없이 DB에 반영

// # Prisma Client 재생성
// pnpm prisma generate

// # DB 상태를 스키마에 반영
// pnpm prisma db pull

// # 스키마를 바로 DB에 반영(마이그레이션 없음)
// pnpm prisma db push

generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model training_sentence {
  id                     Int      @id @default(autoincrement())
  difficulty             Int // 난이도
  sentence               String // 문장 (원문)
  recommended_chunking   String // 권장 청크 분할
  expected_failure_point String // 예상 실패 포인트 (리듬 끊김 위치)
  polysemy               String // 다의어
  word_count             Int // 단어 수
  diagnostic_tags        String[] // 진단태그
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
}
